// glane — embed: OpenAI-compatible POST /v1/embeddings → int8 vector cache.
// HARD CAP: at most EMBED_HARD_MAX vectors per invocation (localhost smoke).
// Host must be localhost / 127.0.0.1. sync never auto-embeds.

var EMBED_HARD_MAX = 10
var EMBED_DEFAULT_DIM = 64
var EMBED_DEFAULT_URL = "http://127.0.0.1:8095/v1/embeddings"
// Cap chars sent to the embedder — long chunks stall fragile localhost.
var EMBED_MAX_CHARS = 256

// embed_hard_max: default 10 (laptop smoke). Raise via GLANE_EMBED_HARD_MAX
// for dogfood against a localhost box you control (still localhost-only).
func embed_hard_max() (n) {
    n = EMBED_HARD_MAX
    raw := env("GLANE_EMBED_HARD_MAX")
    if trim(raw) != "" {
        v := parse_int(raw)
        if v >= 1 && v <= 500 { n = v }
    }
}

type EmbItem struct { index int  embedding []float }
type EmbResp struct { data []EmbItem  model string }
type FloatVec struct { v []float }

type EmbedStats struct { embedded int  skipped int  dim int  model string  url string  ms int  capped bool }

func embed_url() (u) {
    u = env("GLANE_EMBED_URL")
    if trim(u) == "" { u = EMBED_DEFAULT_URL }
}

func embed_dim() (d) {
    d = EMBED_DEFAULT_DIM
    raw := env("GLANE_EMBED_DIM")
    if trim(raw) != "" {
        v := parse_int(raw)
        if v > 0 { d = v }
    }
}

func embed_max_chars() (n) {
    n = EMBED_MAX_CHARS
    raw := env("GLANE_EMBED_MAXCHARS")
    if trim(raw) != "" {
        v := parse_int(raw)
        if v >= 32 { n = v }
    }
}

// embed_text truncates chunk text for the localhost smoke path.
func embed_text(text) (t) {
    t = text
    n := embed_max_chars()
    if len(t) > n { t = substr(t, 0, n) }
}

// embed_host_ok: M2 safety — only localhost endpoints.
func embed_host_ok(url) (yes) {
    yes = false
    u := to_lower(url)
    if has_prefix(u, "http://127.0.0.1:") || has_prefix(u, "http://127.0.0.1/") { yes = true  return }
    if has_prefix(u, "http://localhost:") || has_prefix(u, "http://localhost/") { yes = true  return }
    if u == "http://127.0.0.1" || u == "http://localhost" { yes = true  return }
}

// quantize_f32_i8: unit-ish vectors → int8 in [-127,127] (scale = 127).
func quantize_f32_i8(v) (q) {
    q = []int{}
    for _, x := range v {
        n := int(x * 127.0 + 0.5)
        if x < 0.0 { n = int(x * 127.0 - 0.5) }
        if n > 127 { n = 127 }
        if n < 0 - 127 { n = 0 - 127 }
        q = append(q, n)
    }
}

func i8_to_u8(v) (u) {
    u = v
    if u < 0 { u = u + 256 }
}

// pack_i8 writes q into an alloc'd buffer (caller frees).
func pack_i8(q) (p) {
    p = alloc(len(q))
    i := 0
    while i < len(q) {
        poke_u8(p, i, i8_to_u8(q[i]))
        i = i + 1
    }
}

// embed_batch_size: texts per HTTP call. Default 5 — serve_qwen3e handles
// small batches; batch 10 has been observed to drop the connection.
func embed_batch_size() (n) {
    n = 5
    raw := env("GLANE_EMBED_BATCH")
    if trim(raw) != "" {
        v := parse_int(raw)
        if v >= 1 && v <= embed_hard_max() { n = v }
    }
}

// embed_fetch POSTs up to EMBED_HARD_MAX texts in ONE request.
// Returns []FloatVec aligned with texts. err: 0 ok, 88 embed fail, 83 bad.
func embed_fetch(texts, dim) (vecs, model, err) {
    vecs = []FloatVec{}
    model = ""
    err = 0
    if len(texts) == 0 { return }
    if len(texts) > embed_hard_max() { err = 83  return }
    url := embed_url()
    if embed_host_ok(url) == false {
        err = 88
        return
    }
    parts := []string{}
    for _, t := range texts { parts = append(parts, json(t)) }
    body := "{\"input\":" + json_arr(parts) + ",\"dimensions\":" + str(dim) + "}"
    hdrs := []string{}
    hdrs = append(hdrs, "Content-Type: application/json")
    // one retry — localhost embedders occasionally drop mid-dogfood
    attempt := 0
    while attempt < 2 {
        status, resp, herr := http_request("POST", url, hdrs, body)
        if herr == "" && status >= 200 && status < 300 {
            parsed := parse(resp, EmbResp{})
            if len(parsed.data) == len(texts) {
                by := make(map[int][]float)
                for _, it := range parsed.data { by[it.index] = it.embedding }
                ok := true
                i := 0
                while i < len(texts) {
                    if has(by, i) == false || len(by[i]) == 0 { ok = false  break }
                    vecs = append(vecs, FloatVec{v: by[i]})
                    i = i + 1
                }
                if ok {
                    model = parsed.model
                    return
                }
            }
            progress("embed: bad response shape (attempt " + str(attempt + 1) + ")")
        } else {
            progress("embed: http status=" + str(status) + " err=" + herr + " (attempt " + str(attempt + 1) + ")")
        }
        vecs = []FloatVec{}
        attempt = attempt + 1
        if attempt < 2 {
            _, _, _ := exec("sleep 1")
        }
    }
    err = 88
}

// chunks_needing_embed: live chunks without a vector, stable order by store index.
func chunks_needing_embed() (out) {
    out = []Chunk{}
    for _, c := range st_chunks {
        if has(st_vec_map, c.id) { continue }
        if doc_is_deleted(c.doc) { continue }
        out = append(out, c)
    }
}

// embed_chunks_capped embeds at most `limit` missing chunks (clamped to HARD_MAX).
func embed_chunks_capped(limit) (stats, err) {
    err = 0
    stats = EmbedStats{embedded: 0, skipped: 0, dim: embed_dim(), model: "", url: embed_url(), ms: 0, capped: false}
    if embed_host_ok(stats.url) == false {
        err = 88
        return
    }
    hard := embed_hard_max()
    if limit < 1 { limit = hard }
    if limit > hard { limit = hard  stats.capped = true }
    need := chunks_needing_embed()
    stats.skipped = len(need)
    if len(need) > limit {
        // take first `limit` only
        trimmed := []Chunk{}
        i := 0
        while i < limit { trimmed = append(trimmed, need[i])  i = i + 1 }
        need = trimmed
        stats.capped = true
    }
    stats.skipped = stats.skipped - len(need)
    if len(need) == 0 { return }
    // Small batches (default 5): faster than 1-by-1, stable on serve_qwen3e.
    t0 := now_ms()
    recs := []VecRec{}
    bsz := embed_batch_size()
    i2 := 0
    while i2 < len(need) {
        texts := []string{}
        batch := []Chunk{}
        while i2 + len(batch) < len(need) && len(batch) < bsz {
            c := need[i2 + len(batch)]
            batch = append(batch, c)
            texts = append(texts, embed_text(c.text))
        }
        progress("embed: " + str(i2 + 1) + "-" + str(i2 + len(batch)) + "/" + str(len(need)) + " batch=" + str(len(batch)))
        vecs, model, ferr := embed_fetch(texts, stats.dim)
        if ferr != 0 { err = ferr  stats.ms = now_ms() - t0  return }
        stats.model = model
        bi := 0
        while bi < len(batch) {
            q := quantize_f32_i8(vecs[bi].v)
            if stats.dim != len(q) { stats.dim = len(q) }
            one := []VecRec{}
            one = append(one, VecRec{id: batch[bi].id, dim: len(q), q: q})
            store_add_vectors(one)
            recs = append(recs, one[0])
            bi = bi + 1
        }
        i2 = i2 + len(batch)
    }
    stats.ms = now_ms() - t0
    stats.embedded = len(recs)
}

func cmd_embed(limit) {
    lerr := store_load()
    if lerr != 0 { fail(81, "GLANE_NO_STORE", "no .glane store here; run `glane init` first", true, []string{"glane init"}) }
    hard := embed_hard_max()
    if limit < 1 { limit = hard }
    if limit > hard {
        fail(83, "GLANE_BAD_INPUT", "embed limit cannot exceed " + str(hard) + " (set GLANE_EMBED_HARD_MAX to raise for dogfood)", true, []string{"glane embed --limit " + str(hard), "export GLANE_EMBED_HARD_MAX=100"})
    }
    url := embed_url()
    if embed_host_ok(url) == false {
        fail(88, "GLANE_EMBED", "GLANE_EMBED_URL must be localhost/127.0.0.1 (got " + url + ")", true, []string{"export GLANE_EMBED_URL=http://127.0.0.1:8095/v1/embeddings"})
    }
    progress("embed: url=" + url + " dim=" + str(embed_dim()) + " limit=" + str(limit))
    stats, err := embed_chunks_capped(limit)
    if err == 88 { fail(88, "GLANE_EMBED", "embedding request failed (is serve_qwen3e up on localhost?)", true, []string{"curl -s http://127.0.0.1:8095/health", "check GLANE_EMBED_URL"}) }
    if err == 83 { fail(83, "GLANE_BAD_INPUT", "embed batch too large", true, []string{}) }
    if err != 0 { fail(84, "GLANE_IO", "embed persist failed", false, []string{}) }
    println(json(stats))
}
