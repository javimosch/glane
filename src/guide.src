// glane — guide / help-json / version: the embedded operator manual.

func cmd_version() {
    println("{\"name\":\"glane\",\"version\":\"" + glane_version + "\"}")
}

func help_catalog() (s) {
    s = "[" +
        "{\"name\":\"init\",\"usage\":\"glane init\",\"summary\":\"create the .glane store in cwd\"}," +
        "{\"name\":\"scan\",\"usage\":\"glane scan <path>\",\"summary\":\"walk files -> doc manifest JSON on stdout (respects .glaneignore; skips .git/.glane/binaries)\"}," +
        "{\"name\":\"chunk\",\"usage\":\"glane chunk [--from-scan <path>]\",\"summary\":\"manifest JSON on stdin -> content-addressed chunks JSON (markdown-aware, ~2000-byte windows)\"}," +
        "{\"name\":\"extract\",\"usage\":\"glane extract\",\"summary\":\"chunks JSON on stdin -> nodes/edges JSON (deterministic markdown/code/json parsers)\"}," +
        "{\"name\":\"commit\",\"usage\":\"glane commit\",\"summary\":\"extract/chunk-set JSON on stdin -> persist as a new generation (known ids skipped; missing docs tombstoned when full manifest given)\"}," +
        "{\"name\":\"sync\",\"usage\":\"glane sync <path>\",\"summary\":\"scan+chunk+extract+commit in-process -> stats JSON (does NOT embed)\"}," +
        "{\"name\":\"embed\",\"usage\":\"glane embed [--limit N]\",\"summary\":\"embed up to N missing chunks via localhost OpenAI-compatible endpoint (hard max 10); writes int8 vectors.jsonl\"}," +
        "{\"name\":\"search\",\"usage\":\"glane search <query> [--limit N] [--mode lexical|semantic|hybrid]\",\"summary\":\"lexical BM25 (default), semantic int8 cosine, or hybrid RRF\"}," +
        "{\"name\":\"query\",\"usage\":\"glane query <neighbors|path|subgraph> ...\",\"summary\":\"graph ops over live nodes/edges (neighbors, shortest path, depth-limited subgraph)\"}," +
        "{\"name\":\"log\",\"usage\":\"glane log [--limit N]\",\"summary\":\"generation ledger newest-first (commits.jsonl)\"}," +
        "{\"name\":\"diff\",\"usage\":\"glane diff [<from> <to>]\",\"summary\":\"changes in generations (from, to]; default = last gen vs previous\"}," +
        "{\"name\":\"forget\",\"usage\":\"glane forget <path|doc:path|node-id>\",\"summary\":\"tombstone a live doc or node as a new generation (honest delete)\"}," +
        "{\"name\":\"status\",\"usage\":\"glane status\",\"summary\":\"store stats JSON (gen, docs, chunks, nodes, edges, vectors, bytes)\"}," +
        "{\"name\":\"bench\",\"usage\":\"glane bench [--docs 1000]\",\"summary\":\"self-benchmark on a synthetic corpus -> one JSON report (sequential, modest RSS; no embed)\"}," +
        "{\"name\":\"guide\",\"usage\":\"glane guide [--human]\",\"summary\":\"embedded operator manual (JSON; --human for text)\"}," +
        "{\"name\":\"help-json\",\"usage\":\"glane help-json\",\"summary\":\"this machine-readable command catalog\"}," +
        "{\"name\":\"version\",\"usage\":\"glane version\",\"summary\":\"name + semver JSON\"}," +
        "{\"name\":\"feedback\",\"usage\":\"glane feedback <text>\",\"summary\":\"append feedback to .glane/feedback.jsonl (never fails)\"}" +
        "]"
}

func cmd_help_json() {
    println("{\"name\":\"glane\",\"version\":\"" + glane_version + "\",\"commands\":" + help_catalog() + "}")
}

func cmd_guide(human) {
    if human {
        println("glane " + glane_version + " -- agent-first knowledge engine (M3: generations + forget)")
        println("")
        println("Store: .glane/ — graph is source of truth; BM25 + vectors.jsonl are rebuildable caches.")
        println("Generations: every sync/commit/forget appends to commits.jsonl (log/diff/forget).")
        println("Embeddings: optional, localhost-only, hard-capped at 10 vectors/run (smoke-safe).")
        println("")
        println("Pipeline:  glane init && glane sync <path> && glane search <q>")
        println("           glane log && glane diff && glane forget path/to/doc.md")
        println("")
        println("Exit codes: 0 OK | 80..89 as before | 90 FORGET_MISS")
        return
    }
    ec := "[" +
        "{\"exit\":0,\"code\":\"OK\",\"meaning\":\"success\"}," +
        "{\"exit\":80,\"code\":\"GLANE_USAGE\",\"meaning\":\"bad usage or unknown command\"}," +
        "{\"exit\":81,\"code\":\"GLANE_NO_STORE\",\"meaning\":\"no .glane store in cwd; run glane init\"}," +
        "{\"exit\":82,\"code\":\"GLANE_EXISTS\",\"meaning\":\"store already exists\"}," +
        "{\"exit\":83,\"code\":\"GLANE_BAD_INPUT\",\"meaning\":\"malformed JSON on stdin or bad flag value\"}," +
        "{\"exit\":84,\"code\":\"GLANE_IO\",\"meaning\":\"file read/write failure\"}," +
        "{\"exit\":85,\"code\":\"GLANE_NOT_FOUND\",\"meaning\":\"scan path does not exist\"}," +
        "{\"exit\":86,\"code\":\"GLANE_NO_NODE\",\"meaning\":\"query target node missing or tombstoned\"}," +
        "{\"exit\":87,\"code\":\"GLANE_NO_PATH\",\"meaning\":\"no path within max-hops\"}," +
        "{\"exit\":88,\"code\":\"GLANE_EMBED\",\"meaning\":\"embedding endpoint error or non-localhost URL\"}," +
        "{\"exit\":89,\"code\":\"GLANE_NO_VECTORS\",\"meaning\":\"semantic search with empty vector cache\"}," +
        "{\"exit\":90,\"code\":\"GLANE_FORGET_MISS\",\"meaning\":\"forget selector matches nothing live\"}" +
        "]"
    st := "{\"dir\":\".glane\",\"files\":{\"config.json\":\"store metadata (store_version=3)\",\"docs.jsonl\":\"doc rows, latest-wins per path; deleted=gen tombstone\",\"chunks.jsonl\":\"append-only content-addressed chunks\",\"nodes.jsonl\":\"graph nodes (live = gen_removed==0)\",\"edges.jsonl\":\"graph edges with provenance\",\"commits.jsonl\":\"generation ledger\",\"bm25/postings.json\":\"rebuildable BM25 index\",\"vectors.jsonl\":\"rebuildable int8 embedding cache\",\"feedback.jsonl\":\"operator feedback\"}}"
    ex := "[" +
        "\"glane init\"," +
        "\"glane sync .\"," +
        "\"glane log --limit 5\"," +
        "\"glane diff\"," +
        "\"glane forget stale.md\"," +
        "\"glane search 'error handling' --mode hybrid --limit 5\"," +
        "\"glane bench --docs 1000\"" +
        "]"
    println("{\"name\":\"glane\",\"version\":\"" + glane_version + "\"," +
        "\"tagline\":\"agent-first knowledge engine: graph-first, versioned generations, BM25 + optional int8 vectors\"," +
        "\"contract\":{\"stdout\":\"JSON data only\",\"stderr\":\"progress/diagnostics\",\"errors\":\"{error:{code,message,recoverable,suggestions}} on stdout\",\"deterministic\":true}," +
        "\"exit_codes\":" + ec + "," +
        "\"store\":" + st + "," +
        "\"chunking\":{\"markdown\":\"split on heading lines\",\"window_bytes\":2000,\"boundary\":\"last newline in window\",\"id\":\"sha256(chunk text)\"}," +
        "\"extract\":{\"source\":\"parser\",\"kinds\":[\"doc\",\"chunk\",\"heading\",\"link\",\"symbol\",\"jsonkey\"],\"rels\":[\"has_chunk\",\"has_heading\",\"links_to\",\"refs\",\"defines\",\"has_key\"]}," +
        "\"embed\":{\"url_env\":\"GLANE_EMBED_URL\",\"default_url\":\"http://127.0.0.1:8095/v1/embeddings\",\"dim_env\":\"GLANE_EMBED_DIM\",\"default_dim\":64,\"maxchars_env\":\"GLANE_EMBED_MAXCHARS\",\"default_maxchars\":256,\"hard_max\":10,\"host\":\"localhost/127.0.0.1 only\",\"quant\":\"int8 scale 127\",\"batch\":\"one HTTP call per chunk\",\"sync_embeds\":false}," +
        "\"search\":{\"modes\":[\"lexical\",\"semantic\",\"hybrid\"],\"lexical\":\"BM25 k1=1.2 b=0.75\",\"semantic\":\"int8 cosine brute-force\",\"hybrid\":\"reciprocal rank fusion k=60\"}," +
        "\"ignore\":{\"file\":\".glaneignore\",\"rules\":[\"*.ext suffix\",\"dir/ prefix\",\"name exact|basename|prefix\",\"# comment\"],\"always_skipped\":[\".git\",\".glane\",\"binary extensions\",\"NUL-sniffed files\"]}," +
        "\"commands\":" + help_catalog() + "," +
        "\"examples\":" + ex + "}")
}

// cmd_feedback appends to .glane/feedback.jsonl; never fails.
func cmd_feedback(text) {
    stored := false
    if store_exists() {
        append_lines(st_dir + "/feedback.jsonl", "{\"ts\":" + str(now()) + ",\"text\":" + json(text) + "}\n")
        stored = true
    }
    sv := "false"
    if stored { sv = "true" }
    println("{\"ok\":true,\"stored\":" + sv + "}")
}
