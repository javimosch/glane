// glane — context: the killer verb.
// Seed via search → expand along graph edges → dedupe → pack under a token budget.
// Token estimate: ceil(chars/4). No LLM calls.

type CtxChunk struct { id string  doc string  text string  score float  why string }
type CtxEntity struct { id string  kind string  name string }
type CtxCite struct { chunk string  doc string }
type ContextPack struct {
    task string
    budget int
    used int
    mode string
    chunks []CtxChunk
    entities []CtxEntity
    citations []CtxCite
}

func est_tokens(s) (n) {
    n = (len(s) + 3) / 4
    if n < 1 && len(s) > 0 { n = 1 }
}

// content_token: skip English stopwords / tiny words so "how do I use X"
// does not boost every prose chunk equally (dogfood gap on machin docs).
func content_token(tok) (yes) {
    yes = false
    if len(tok) < 4 { return }
    if tok == "what" || tok == "when" || tok == "where" || tok == "which" || tok == "with" || tok == "this" || tok == "that" || tok == "from" || tok == "have" || tok == "does" || tok == "into" || tok == "about" || tok == "should" || tok == "would" || tok == "could" || tok == "their" || tok == "there" || tok == "these" || tok == "those" || tok == "your" || tok == "more" || tok == "than" || tok == "then" || tok == "them" || tok == "been" || tok == "were" || tok == "will" || tok == "just" || tok == "like" || tok == "also" || tok == "only" || tok == "over" || tok == "such" || tok == "some" || tok == "very" || tok == "into" || tok == "how" || tok == "use" || tok == "using" || tok == "used" || tok == "make" || tok == "made" || tok == "work" || tok == "works" || tok == "working" || tok == "get" || tok == "got" || tok == "set" || tok == "run" || tok == "running" || tok == "need" || tok == "needs" || tok == "want" || tok == "know" || tok == "name" || tok == "file" || tok == "files" || tok == "code" || tok == "function" { return }
    yes = true
}

// path_boost raises chunks whose doc path/basename overlaps query tokens.
// Critical for RAG: "how does sync work" should prefer src/main.src over noise.
func path_boost(doc, task) (b) {
    b = 0.0
    if doc == "" || task == "" { return }
    dl := to_lower(doc)
    base := to_lower(basename(doc))
    for _, tok := range tokenize(task) {
        if content_token(tok) == false { continue }
        tl := to_lower(tok)
        // prefer basename / file stem over parent-dir matches (skills/machin-*)
        if contains(base, tl) { b = b + 5.0 }
        if has_suffix(base, tl + ".src") || has_suffix(base, tl + ".md") { b = b + 3.0 }
        // weaker: directory segment match
        if contains(dl, "/" + tl) || contains(dl, tl + "/") || contains(dl, tl + "-") || contains(dl, "-" + tl) { b = b + 1.0 }
    }
}

// term_coverage: content-token overlap. Partial matches of short queries
// are penalized — dogfood "machin encode" must not prefer skills/machin-*
// that only match the path token "machin" and miss "encode".
func term_coverage(text, task) (b) {
    b = 0.0
    if text == "" || task == "" { return }
    tl := to_lower(text)
    hit := 0
    n := 0
    for _, tok := range tokenize(task) {
        if content_token(tok) == false { continue }
        n = n + 1
        if contains(tl, to_lower(tok)) { hit = hit + 1 }
    }
    if n == 0 { return }
    // hard-require long tokens (len>=6): "encode", "selfhost", "performance"
    // shorter ones ("notes") are soft — avoid over-demoting real hits
    miss_long := 0
    for _, tok2 := range tokenize(task) {
        if content_token(tok2) == false { continue }
        if len(tok2) < 6 { continue }
        if contains(tl, to_lower(tok2)) == false { miss_long = miss_long + 1 }
    }
    if miss_long > 0 {
        b = 0.0 - float(miss_long) * 10.0
        return
    }
    b = (float(hit) / float(n)) * 6.0
    if hit == n { b = b + 4.0 }
}

// content_query keeps distinctive tokens so BM25 is not flooded by
// "how do I use …" stopword matches (dogfood gap on natural-language Qs).
func content_query(task) (q) {
    q = ""
    parts := []string{}
    for _, tok := range tokenize(task) {
        if content_token(tok) { parts = append(parts, tok) }
    }
    if len(parts) == 0 { q = task  return }
    q = join(parts, " ")
}

// context_seed runs search for the task; prefers hybrid only when vectors exist
// and mode asks for it — otherwise lexical (localhost-safe default).
func context_seed(task, limit, mode) (hits, used_mode, err) {
    hits = []SearchHit{}
    used_mode = mode
    err = 0
    if mode == "" { mode = "auto"  used_mode = "auto" }
    if mode == "auto" {
        if live_vec_count() > 0 { used_mode = "hybrid" } else { used_mode = "lexical" }
    }
    q := content_query(task)
    hits, err = search_dispatch(q, limit, used_mode)
    // hybrid/semantic embed failure → fall back to lexical
    if err == 88 || err == 89 {
        hits = bm25_search(q, limit)
        used_mode = "lexical"
        err = 0
    }
    // re-rank seeds: path + term coverage so distinctive query words win
    // (dogfood: "machin encode" must beat docs that only match stopwordy BM25)
    if err == 0 && len(hits) > 1 {
        i := 0
        while i < len(hits) {
            hits[i].score = hits[i].score + path_boost(hits[i].doc, task)
            c1, ok1 := chunk_by_id(hits[i].chunk)
            if ok1 { hits[i].score = hits[i].score + term_coverage(c1.text, task) * 3.0 }
            i = i + 1
        }
        // simple insertion sort by score desc, then chunk id
        j := 1
        while j < len(hits) {
            k := j
            while k > 0 && (hits[k].score > hits[k - 1].score || (hits[k].score == hits[k - 1].score && hits[k].chunk < hits[k - 1].chunk)) {
                t := hits[k]  hits[k] = hits[k - 1]  hits[k - 1] = t
                k = k - 1
            }
            j = j + 1
        }
    }
}

// expand_from_hit collects related live chunk ids via the doc's graph neighborhood.
func expand_from_hit(h, depth, seen_chunks, seen_nodes, out_chunks, out_nodes) (oc, on) {
    oc = out_chunks
    on = out_nodes
    if has(seen_chunks, h.chunk) == false {
        seen_chunks[h.chunk] = 1
        oc = append(oc, h.chunk)
    }
    did := "doc:" + h.doc
    queue := []string{}
    dist := make(map[string]int)
    if has(st_node_map, did) {
        queue = append(queue, did)
        dist[did] = 0
        seen_nodes[did] = 1
        on = append(on, did)
    }
    // also seed from chunk node if present
    cid := "chunk:" + h.chunk
    if has(st_node_map, cid) && has(seen_nodes, cid) == false {
        queue = append(queue, cid)
        dist[cid] = 0
        seen_nodes[cid] = 1
        on = append(on, cid)
    }
    qi := 0
    while qi < len(queue) {
        cur := queue[qi]
        qi = qi + 1
        if dist[cur] >= depth { continue }
        for _, ei := range collect_adj(cur, "both") {
            e := st_edges[ei]
            if edge_live(e) == false { continue }
            nxt := e.dst
            if e.src != cur { nxt = e.src }
            if has(seen_nodes, nxt) { continue }
            on2, ook := find_node(nxt)
            if ook == false { continue }
            seen_nodes[nxt] = 1
            dist[nxt] = dist[cur] + 1
            on = append(on, nxt)
            queue = append(queue, nxt)
            // pull chunks linked from this node
            if on2.kind == "chunk" && has_prefix(nxt, "chunk:") {
                chid := substr(nxt, 6, len(nxt))
                if has(seen_chunks, chid) == false {
                    seen_chunks[chid] = 1
                    oc = append(oc, chid)
                }
            }
            if on2.kind == "doc" && has_prefix(nxt, "doc:") {
                // all has_chunk edges out of this doc
                for _, ei2 := range collect_adj(nxt, "out") {
                    e2 := st_edges[ei2]
                    if edge_live(e2) == false { continue }
                    if e2.rel != "has_chunk" { continue }
                    if has_prefix(e2.dst, "chunk:") {
                        ch2 := substr(e2.dst, 6, len(e2.dst))
                        if has(seen_chunks, ch2) == false {
                            seen_chunks[ch2] = 1
                            oc = append(oc, ch2)
                        }
                    }
                }
            }
            // provenance chunk ids on the edge
            for _, p := range e.provenance {
                if has(seen_chunks, p) == false {
                    seen_chunks[p] = 1
                    oc = append(oc, p)
                }
            }
        }
    }
}

func chunk_by_id(id) (c, ok) {
    ok = false
    c = Chunk{}
    if has(st_chunk_map, id) == false { return }
    c = st_chunks[st_chunk_map[id]]
    if doc_is_deleted(c.doc) { return }
    ok = true
}

// build_context assembles a ContextPack under budget tokens.
func build_context(task, budget, seeds, depth, mode) (pack, err) {
    err = 0
    pack = ContextPack{task: task, budget: budget, used: 0, mode: mode, chunks: []CtxChunk{}, entities: []CtxEntity{}, citations: []CtxCite{}}
    if budget < 64 { err = 83  return }
    if seeds < 1 { seeds = 8 }
    if seeds > 32 { seeds = 32 }
    if depth < 0 { depth = 1 }
    if depth > 3 { depth = 3 }
    hits, used_mode, serr := context_seed(task, seeds, mode)
    if serr != 0 { err = serr  return }
    pack.mode = used_mode
    seed_score := make(map[string]float)
    seed_why := make(map[string]string)
    for _, h := range hits {
        seed_score[h.chunk] = h.score
        seed_why[h.chunk] = "seed"
    }
    seen_c := make(map[string]int)
    seen_n := make(map[string]int)
    cand := []string{}
    ents := []string{}
    for _, h2 := range hits {
        cand, ents = expand_from_hit(h2, depth, seen_c, seen_n, cand, ents)
    }
    // rank candidates: seed score first, then graph-only at 0
    // selection loop fills budget
    picked := make(map[string]int)
    used := 0
    // reserve ~10% for entity summaries
    chunk_budget := (budget * 9) / 10
    if chunk_budget < 32 { chunk_budget = budget }
    while used < chunk_budget {
        best := ""
        best_sc := -1.0
        for _, id := range cand {
            if has(picked, id) { continue }
            sc := 0.0
            if has(seed_score, id) { sc = seed_score[id] }
            c0, ok0 := chunk_by_id(id)
            if ok0 {
                sc = sc + path_boost(c0.doc, task)
                sc = sc + term_coverage(c0.text, task)
            }
            if best == "" || sc > best_sc || (sc == best_sc && id < best) {
                best = id
                best_sc = sc
            }
        }
        if best == "" { break }
        picked[best] = 1
        c, ok := chunk_by_id(best)
        if ok == false { continue }
        why := "graph"
        if has(seed_why, best) { why = seed_why[best] }
        text := c.text
        // trim text if a single chunk would blow the remaining budget
        tok := est_tokens(text)
        remain := chunk_budget - used
        if tok > remain && remain > 16 {
            // approx chars for remain tokens
            maxc := remain * 4
            if maxc < len(text) { text = substr(text, 0, maxc)  tok = est_tokens(text) }
        }
        if used + tok > chunk_budget && used > 0 { break }
        pack.chunks = append(pack.chunks, CtxChunk{id: best, doc: c.doc, text: text, score: best_sc, why: why})
        pack.citations = append(pack.citations, CtxCite{chunk: best, doc: c.doc})
        used = used + tok
    }
    // entity summaries (name + kind), cheapest first, fill remaining budget
    for _, nid := range ents {
        if used >= budget { break }
        n, ok := find_node(nid)
        if ok == false { continue }
        if n.kind == "chunk" { continue }
        line := n.kind + ": " + n.name
        t := est_tokens(line)
        if used + t > budget { continue }
        pack.entities = append(pack.entities, CtxEntity{id: n.id, kind: n.kind, name: n.name})
        used = used + t
    }
    pack.used = used
}

func context_json(pack) (s) {
    cparts := []string{}
    for _, c := range pack.chunks { cparts = append(cparts, json(c)) }
    eparts := []string{}
    for _, e := range pack.entities { eparts = append(eparts, json(e)) }
    iparts := []string{}
    for _, i := range pack.citations { iparts = append(iparts, json(i)) }
    s = "{\"task\":" + json(pack.task) + ",\"budget\":" + str(pack.budget) + ",\"used\":" + str(pack.used) + ",\"mode\":" + json(pack.mode) +
        ",\"chunks\":" + json_arr(cparts) + ",\"entities\":" + json_arr(eparts) + ",\"citations\":" + json_arr(iparts) + "}"
}

func cmd_context(task, budget, seeds, depth, mode) {
    lerr := store_load()
    if lerr != 0 { fail(81, "GLANE_NO_STORE", "no .glane store here; run `glane init` first", true, []string{"glane init"}) }
    if trim(task) == "" { fail(83, "GLANE_BAD_INPUT", "context needs a task description", true, []string{"glane context \"fix the sync path\" --budget 2000"}) }
    pack, err := build_context(task, budget, seeds, depth, mode)
    if err == 83 { fail(83, "GLANE_BAD_INPUT", "--budget must be >= 64", true, []string{}) }
    if err != 0 { fail(84, "GLANE_IO", "context build failed", false, []string{}) }
    println(context_json(pack))
}
